{
  "name": "pixel-pal-web",
  "productName": "PixelPal",
  "version": "1.0.0",
  "description": "AI Companion Desktop App",
  "author": "YeLuo45",
  "homepage": "https://YeLuo45.github.io/pixel-pal-web",
  "private": true,
  "type": "module",
  "npmRebuild": false,
  "buildDependenciesFromSource": false,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "package": "npm run build && electron-builder --win --x64",
    "package:dir": "npm run build && electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.17.0",
    "@mui/material": "^5.17.0",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "i18next": "^24.2.3",
    "idb": "^8.0.3",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^3.11.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.5.1",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0",
    "uuid": "^13.0.0",
    "wordcloud": "^1.2.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.pixel-pal.app",
    "productName": "PixelPal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "publish": null,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
